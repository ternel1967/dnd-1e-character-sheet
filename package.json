{
  "name": "dnd-1e-character-sheet",
  "version": "1.0.0",
  "description": "Interactive 1st Edition D&D Character Sheet with Multi-Character Support",
  "main": "electron.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build:electron": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "pinia": "^2.1.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "vite": "^8.0.3",
    "wait-on": "^7.0.0"
  }
}
